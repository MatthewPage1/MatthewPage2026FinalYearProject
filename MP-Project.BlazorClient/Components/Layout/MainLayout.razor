@inject ThemeService ThemeService
@implements IDisposable
@inherits LayoutComponentBase

<div class="app-container @(ThemeService.CurrentTheme)">

    <!-- Sidebar -->
    <div class="sidebar">
        <NavLink href="/" class="nav-item">Dashboard</NavLink>
        <NavLink href="/item-list" class="nav-item">Item List</NavLink>
        <NavLink href="/inventory-updates" class="nav-item">Inventory Updates</NavLink>
        <NavLink href="/purchases" class="nav-item">Purchases</NavLink>
        <NavLink href="/profile" class="nav-item">Profile</NavLink>
        <NavLink href="/settings" class="nav-item">Settings</NavLink>

        <div class="bottom-link">
            <NavLink href="/" class="nav-item">Log In / Sign Up</NavLink>
        </div>
    </div>

    <!-- Main Area -->
    <div class="main-content">
        <div class="header">
            Inventory Management System
        </div>

        <div class="page-content">
            @Body
        </div>
    </div>

</div>

@code {

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += Refresh;
    }

    private async void Refresh()
    {
        await InvokeAsync(() =>
        {
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= Refresh;
    }
}