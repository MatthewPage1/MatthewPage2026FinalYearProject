@page "/purchases"
@inject IHttpClientFactory ClientFactory
@using MP_Project.Shared

<div class="content-card">

    <div class="section-title">
        Purchases
    </div>

    <div class="search-bar-container">
        <input type="text"
               placeholder="Search Supplier..."
               @bind="searchText"
               @bind:event="oninput" />
    </div>

    <div class="purchase-header">
        <span>Supplier</span>
        <span>Contact</span>
        <span>Product</span>
        <span>Total</span>
        <span>Delivery</span>
        <span>Status</span>
        <span>Checked In</span>
    </div>

    <div class="purchase-scroll">

        @foreach (var t in FilteredTransactions)
        {
            <div class="purchase-row @(t.Processed && !t.CheckedIn ? "row-action" : "")"
                 @onclick="() => HandleRowClick(t)">

                <span>@t.SupplierName</span>

                <span>@t.SupplierEmail<br />@t.SupplierPhone</span>

                <span>@t.Quantity x @t.ProductName</span>

                <span>£@t.TotalPrice</span>

                <span>@t.DeliveryDate.ToShortDateString()</span>

                <span>
                    <span class="delivery-status @(t.Processed ? "delivered" : "pending")">
                        @(t.Processed ? "Delivered" : "Pending")
                    </span>
                </span>

                <span class="checkin-indicator">
                    @if (t.CheckedIn)
                    {
                        <span class="check-true">☑</span>
                    }
                    else
                    {
                        <span class="check-false">☒</span>
                    }
                </span>

            </div>
        }

    </div>

    <button class="btn btn-success"
			disabled="@(DeliveriesToCheckIn == 0)"
            @onclick="CheckInAllDeliveries">
        @(DeliveriesToCheckIn == 0
                ? "No Deliveries To Check In"
                : $"Check In {DeliveriesToCheckIn} {(DeliveriesToCheckIn == 1 ? "Delivery" : "Deliveries")}")
    </button>

</div>

@code {

private string searchText = "";
    private List<PurchaseDto> transactions = new();

    protected override async Task OnInitializedAsync()
    {
        var http = ClientFactory.CreateClient("API");

        await http.PostAsync("api/SupplierTransactions/processDeliveries", null);

        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        var http = ClientFactory.CreateClient("API");

        var result = await http.GetFromJsonAsync<List<PurchaseDto>>("api/suppliertransactions");

        if (result != null)
            transactions = result;
    }

    private async Task CheckInSingleDelivery(int transactionId)
    {
        var http = ClientFactory.CreateClient("API");

        await http.PostAsJsonAsync(
            "api/SupplierTransactions/checkInDelivery",
            transactionId
        );

        await LoadTransactions();
    }

    private async Task CheckInAllDeliveries()
    {
        var http = ClientFactory.CreateClient("API");

        await http.PostAsync(
            "api/SupplierTransactions/checkInAllDeliveries",
            null
        );

        await LoadTransactions();
    }

    private IEnumerable<PurchaseDto> FilteredTransactions =>
        string.IsNullOrWhiteSpace(searchText)
            ? transactions
            : transactions.Where(t =>
                t.SupplierName != null &&
                t.SupplierName.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    private async Task HandleRowClick(PurchaseDto t)
    {
        if (!t.Processed || t.CheckedIn)
            return;

        await CheckInSingleDelivery(t.TransactionID);
    }

    private int DeliveriesToCheckIn =>
    transactions.Count(t => t.Processed && !t.CheckedIn);

}
