@page "/purchases"
@inject IHttpClientFactory ClientFactory
@using MP_Project.Shared

<div class="content-card">

    <div class="section-title">
        Purchases
    </div>

    <div class="purchase-list">

        @foreach (var t in transactions)
        {
            <div class="purchase-row">

                <span><strong>ID:</strong> @t.TransactionID</span>

                <span><strong>Product:</strong> @t.ProductID</span>

                <span><strong>Supplier:</strong> @t.SupplierID</span>

                <span><strong>Quantity:</strong> @t.Quantity</span>

                <span><strong>Total:</strong> £@t.TotalPrice</span>

                <span><strong>Ordered:</strong> @t.TransactionDate.ToShortDateString()</span>

                <span><strong>Delivery:</strong> @t.DeliveryDate.ToShortDateString()</span>

                <span>
                    <strong>Status:</strong>
                    <span class="delivery-status @(t.Processed ? "delivered" : "pending")">
                        @(t.Processed ? "Delivered" : "Pending")
                    </span>
                </span>

            </div>
        }

    </div>

</div>

@code {

    private List<SupplierTransaction> transactions = new();

    protected override async Task OnInitializedAsync()
    {
        var http = ClientFactory.CreateClient("API");

        //process deliveries first
        await http.PostAsync("api/SupplierTransactions/processDeliveries", null);

        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        var http = ClientFactory.CreateClient("API");

        var result = await http.GetFromJsonAsync<List<SupplierTransaction>>("api/suppliertransactions");

        if (result != null)
            transactions = result;
    }

}