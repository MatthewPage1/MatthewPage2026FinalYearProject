@page "/"
@page "/item-list"
@inject IHttpClientFactory ClientFactory
@using MP_Project.Shared

<div class="content-card">
    <div class="section-title">
        Item List
    </div>

    <div class="search-bar-container">
        <input type="text"
               placeholder="Search product..."
               @bind="searchText"
               @bind:event="oninput" />
    </div>

    <div class="product-list">
        @foreach (var product in FilteredProducts)
        {
            <div class="product-row"
                @onclick="() => OpenModal(product)">
                <div class="product-image-box">
                    @if (!string.IsNullOrWhiteSpace(product.Image))
                    {
                        <img src="@product.Image" alt="@product.ProductName" />
                    }
                    else
                    {
                        <span>No Image</span>
                    }
                </div>

                <div class="product-info-box">
                    <div class="product-meta">
                        <span><strong>ID:</strong> @product.ProductId</span>
                        <span>
                            <strong>Quantity:</strong> @product.StockCount
							<span class="stock-badge @GetStockColour(product.StockCount)">
                                @GetStockStatus(product.StockCount)
                            </span>
                        </span>
                    </div>

                    <p class="product-description-text">
                        @product.ProductDescription
                    </p>
                </div>
            </div>
        }
    </div>
</div>

@if (selectedProduct != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-container" @onclick:stopPropagation="true">

            <div class="modal-header">
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>

            <div class="modal-body">

                <div class="modal-grid">

                    <!-- LEFT SIDE -->
                    <div class="modal-left">

                        @if (!string.IsNullOrWhiteSpace(selectedProduct?.Image))
                        {
                            <img src="@selectedProduct.Image"
                                 alt="@selectedProduct.ProductName"
                                 class="modal-image" />
                        }

                        <div class="barcode-section">
                            <h5>EAN-13 Barcode</h5>

                            <img src="@($"https://barcode.tec-it.com/barcode.ashx?data={selectedProduct.gtin13}&code=EAN13&translate-esc=false")"
                                 alt="GTIN13 Barcode" />
                        </div>

                    </div>

                    <!-- RIGHT SIDE -->
                    <div class="modal-right">

                        <h3>@selectedProduct?.ProductName</h3>

                        <div class="product-detail"><strong>Brand:</strong> @selectedProduct?.Brand</div>
                        <div class="product-detail"><strong>gtin13:</strong> @selectedProduct?.gtin13</div>

                        <div class="product-detail">
                            <strong>Cost Price:</strong> £@selectedProduct?.CostPrice
                        </div>

                        <div class="product-detail">
                            <strong>Selling Price:</strong> £@selectedProduct?.SellingPrice
                        </div>

                        <div class="product-detail">
                            <strong>Stock:</strong> @selectedProduct?.StockCount
                        </div>

                        <div class="product-detail">
                            <strong>Reorder Level:</strong> @selectedProduct?.ReorderLevel
                        </div>

                        <div class="product-detail">
                            <strong>Availability:</strong> @selectedProduct?.Availability
                        </div>

                        <div class="product-detail">
                            <strong>Group 1:</strong> @selectedProduct?.ProductGroup1
                        </div>

                        <div class="product-detail">
                            <strong>Group 2:</strong> @selectedProduct?.ProductGroup2
                        </div>

                        <div class="product-detail">
                            <strong>Group 3:</strong> @selectedProduct?.ProductGroup3
                        </div>

                        <div class="product-description">
                            <strong>Description:</strong>
                            <p>@selectedProduct?.ProductDescription</p>
                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>
}

@code {

    private Product? selectedProduct;
    private List<Product> products = new();
    private string searchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var http = ClientFactory.CreateClient("API");
        var result = await http.GetFromJsonAsync<List<Product>>("api/products");
        if (result != null)
            products = result;
    }

    private IEnumerable<Product> FilteredProducts =>
        string.IsNullOrWhiteSpace(searchText)
            ? products
            : products.Where(p =>
                p.ProductName != null &&
                p.ProductName.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    //determine the status of stock and apply a colour marker
    private string GetStockColour(int stock)
    {
        if (stock <= 10)
            return "stock-red";

        if (stock <= 20)
            return "stock-orange";

        return "stock-green";
    }

    //determine the status of stock and apply a status
    private string GetStockStatus(int stock)
    {
        if (stock <= 10)
            return "Low";

        if (stock <= 20)
            return "Medium";

        return "Good";
    }

    private void OpenModal(Product product)
    {
        selectedProduct = product;
    }

    private void CloseModal()
    {
        selectedProduct = null;
    }

}